{
  "name": "novel-script-tool",
  "version": "2026.7.0",
  "private": true,
  "type": "module",
  "main": "electron/main.mjs",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "desktop:start": "npm run build && electron .",
    "desktop:unpack": "npm run build && electron-builder --dir --win --x64",
    "desktop:dist": "npm run build && cross-env ELECTRON_BUILDER_BINARIES_MIRROR=https://npmmirror.com/mirrors/electron-builder-binaries/ electron-builder --win nsis --x64",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vitejs/plugin-react": "^5.0.0",
    "electron-updater": "^6.8.9",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.185.1",
    "three-stdlib": "^2.36.1",
    "typescript": "^5.8.0",
    "vite": "^7.0.0",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "cross-env": "^10.1.0",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "jsdom": "^25.0.0",
    "vitest": "^2.1.0"
  },
  "build": {
    "appId": "com.xiaotu.assistant",
    "productName": "小兔助手",
    "asar": true,
    "electronDist": "node_modules/electron/dist",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.mjs",
      "electron/autoUpdate.mjs",
      "electron/desktopServer.mjs",
      "package.json"
    ],
    "win": {
      "signAndEditExecutable": false,
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "artifactName": "Xiaotu-Assistant-Setup-${version}.${ext}"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "xiaotushuoman-ship-it",
        "repo": "novel-script-tool",
        "releaseType": "release"
      }
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "小兔助手",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    }
  }
}
